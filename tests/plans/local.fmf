summary: a-i-b tests running on local machine

environment:
    # Full path to the directory with cloned repository of the project
    PROJECT_DIR: ""

    # Distribution used inside tests.
    # Available distributions can be listed using `aib list-dist` on the relevant platform.
    AIB_DISTRO: autosd10-sig

    # Build boot builder container only when it doesn't exist
    REBUILD_BOOTC_BUILDER: no

    # Some tests require using sudo when executed locally
    SUDO: "sudo"

    # Custom parameters to be passed to `aib build` command used in tests
    AIB_BUILD_OPTIONS: ""

    # Custom parameters to be passed to `aib build-builder` command used in tests
    AIB_BUILD_BUILDER_OPTIONS: ""

    AIB: $PROJECT_DIR/bin/aib
    AIBDEV: $PROJECT_DIR/bin/aib-dev
    AIB_BASEDIR: $PROJECT_DIR
    AIR: $PROJECT_DIR/bin/air
    OUTDIR: /var/tmp/tmt
    BUILDDIR: $OUTDIR/build
    RUNDIR: $OUTDIR/run

provision:
    how: local

prepare:
    - name: Install required packages
      how: install
      package:
        - jq
        - podman
        - sudo

    - name: Setup local environment
      how: shell
      script: |
          ./scripts/setup-local.sh

    - name: Report a-i-b version
      how: shell
      script: |
         ${AIB} --version

    - name: Populate build cache directory
      how: shell
      script: |
          ./scripts/init-build-cache.sh

    - name: Initialize bootc builder container
      how: shell
      script: |
          ./scripts/init-bootc-builder.sh

discover:
    how: fmf
    prune: true
    filter: tag:-special

execute:
    how: tmt

report:
    how: junit

finish:
    - name: Cleanup temporary files
      how: shell
      script: |
          ./scripts/cleanup.sh
