remotes:
  osbuild:
    url: "https://github.com/osbuild/osbuild.git"
    version: "8586e32f3e6247a64a7af7b2296ed835f6a79ddc"

files:
  osbuild:
    - source: "osbuild/util/*.py"
      destination: "mpp/aibosbuild/util"
      exclude:
        - "chroot.py"
        - "host.py"
        - "toml.py"
        - "experimentalflags.py"
      transform:
        - "s/osbuild\\.util/aibosbuild.util/g"

    #- source: "tools/osbuild-mpp"
    #  destination: "mpp/aib-osbuild-mpp"
    #  transform:
    #    - "s/osbuild\\.util/aibosbuild.util/g"
