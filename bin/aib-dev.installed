#!/usr/bin/env python3
# PYTHON_ARGCOMPLETE_OK

import sys

# Hardcoded base directory for installed version
basedir = "/usr/lib/automotive-image-builder"

# Add basedir to Python path
sys.path.insert(0, basedir)

# Save original argv before modifying (for argcomplete)
sys._orig_argv = sys.argv.copy()

# Insert basedir as sys.argv[1] (the module expects it there)
sys.argv.insert(1, basedir)

# Import and run the main module
from aib import main_dev

if __name__ == "__main__":
    sys.exit(main_dev.main())
